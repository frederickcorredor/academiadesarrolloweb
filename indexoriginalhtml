// ==================== STATE ====================
let state = {
  currentLesson: null,
  currentTab: 0,
  quizAnswers: {},
  quizCorrect: 0,
  challengeDone: false,
  progress: {}
};

function loadProgress() {
  try {
    const saved = localStorage.getItem('webkids_progress');
    if (saved) state.progress = JSON.parse(saved);
  } catch(e) { state.progress = {}; }
}

function saveProgress() {
  try {
    localStorage.setItem('webkids_progress', JSON.stringify(state.progress));
  } catch(e) {}
}

function getLessonProgress(id) {
  return state.progress[id] || { completed: false, stars: 0, points: 0 };
}

function getTotalPoints() {
  return Object.values(state.progress).reduce((s, p) => s + (p.points || 0), 0);
}

function getTotalStars() {
  return Object.values(state.progress).reduce((s, p) => s + (p.stars || 0), 0);
}

function getCompletedCount() {
  return Object.values(state.progress).filter(p => p.completed).length;
}

function getTrackProgress(track) {
  const lessons = curriculum[track];
  const done = lessons.filter(l => getLessonProgress(l.id).completed).length;
  return Math.round((done / lessons.length) * 100);
}

function getAllLessons() {
  return [...curriculum.html, ...curriculum.css, ...curriculum.js];
}

// ==================== SIDEBAR BUILD ====================
function buildSidebar() {
  ['html', 'css', 'js'].forEach(track => {
    const section = document.getElementById(track + '-section');
    section.innerHTML = '';
    curriculum[track].forEach((lesson, idx) => {
      const prog = getLessonProgress(lesson.id);
      const allLessons = getAllLessons();
      const globalIdx = allLessons.findIndex(l => l.id === lesson.id);
      const isLocked = globalIdx > 0 && !getLessonProgress(allLessons[globalIdx - 1].id).completed;
      const div = document.createElement('div');
      div.className = `lesson-item${prog.completed ? ' completed' : ''}${state.currentLesson?.id === lesson.id ? ' active' : ''}${isLocked ? ' locked' : ''}`;
      const stars = prog.stars ? '⭐'.repeat(prog.stars) : '';
      div.innerHTML = `
        <span class="lesson-icon">${prog.completed ? '✅' : isLocked ? '🔒' : '📖'}</span>
        <span>${idx + 1}. ${lesson.title}</span>
        ${stars ? `<span class="lesson-stars">${stars}</span>` : ''}
      `;
      if (!isLocked) {
        div.onclick = () => { openLesson(lesson); if(window.innerWidth <= 768) toggleSidebar(); };
      }
      section.appendChild(div);
    });
    // Update progress bar
    document.getElementById(track + '-prog').style.width = getTrackProgress(track) + '%';
  });
}

// ==================== HOME UPDATE ====================
function updateHome() {
  const pts = getTotalPoints();
  const lessons = getCompletedCount();
  const stars = getTotalStars();
  const maxPts = getAllLessons().reduce((s, l) => s + l.xp, 0);
  const maxLessons = getAllLessons().length;
  const maxStars = maxLessons * 5;
  
  document.getElementById('total-points').textContent = pts;
  document.getElementById('streak-count').textContent = Math.floor(lessons / 2);
  document.getElementById('home-points').textContent = pts;
  document.getElementById('home-lessons').textContent = lessons;
  document.getElementById('home-stars').textContent = stars;
  document.getElementById('home-points-bar').style.width = Math.min(100, pts / maxPts * 100) + '%';
  document.getElementById('home-lessons-bar').style.width = Math.min(100, lessons / maxLessons * 100) + '%';
  document.getElementById('home-stars-bar').style.width = Math.min(100, stars / maxStars * 100) + '%';
  
  ['html', 'css', 'js'].forEach(t => {
    document.getElementById('tr-' + t).style.width = getTrackProgress(t) + '%';
  });
}

// ==================== LESSON ====================
function openLesson(lesson) {
  state.currentLesson = lesson;
  state.currentTab = 0;
  state.quizAnswers = {};
  state.quizCorrect = 0;
  state.challengeDone = false;
  
  document.getElementById('home-screen').style.display = 'none';
  const ls = document.getElementById('lesson-screen');
  ls.style.display = 'block';
  
  const allLessons = getAllLessons();
  const idx = allLessons.findIndex(l => l.id === lesson.id);
  document.getElementById('lesson-num').textContent = idx + 1;
  document.getElementById('lesson-title').textContent = lesson.title;
  document.getElementById('lesson-subtitle').textContent = lesson.subtitle;
  document.getElementById('lesson-xp').textContent = '+' + lesson.xp + ' pts';
  
  buildTabs(lesson);
  showTab(0);
  buildSidebar();
  ls.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function buildTabs(lesson) {
  const tabs = document.getElementById('lesson-tabs');
  const tabDefs = [
    { label: '📖 Lección', icon: '📖' },
    { label: '💡 Ejemplos', icon: '💡' },
    { label: '❓ Quiz', icon: '❓' },
    { label: '⌨️ Práctica', icon: '⌨️' }
  ];
  
  tabs.innerHTML = '';
  tabDefs.forEach((t, i) => {
    const btn = document.createElement('button');
    btn.className = 'lesson-tab' + (i === 0 ? ' active' : '');
    btn.textContent = t.label;
    btn.onclick = () => showTab(i);
    tabs.appendChild(btn);
  });
}

function showTab(idx) {
  state.currentTab = idx;
  const tabs = document.querySelectorAll('.lesson-tab');
  tabs.forEach((t, i) => { t.className = 'lesson-tab' + (i === idx ? ' active' : ''); });
  
  const content = document.getElementById('tab-content');
  const lesson = state.currentLesson;
  
  if (idx === 0) content.innerHTML = renderIntro(lesson);
  else if (idx === 1) content.innerHTML = renderExamples(lesson);
  else if (idx === 2) { content.innerHTML = renderQuiz(lesson); }
  else if (idx === 3) content.innerHTML = renderChallenge(lesson);
}

function renderIntro(lesson) {
  return `<div class="tab-pane active"><div class="intro-content">${lesson.intro.content}</div></div>`;
}

function renderExamples(lesson) {
  let html = '<div class="tab-pane active">';
  lesson.examples.forEach((ex, i) => {
    html += `
      <div class="example-section">
        <div class="example-card">
          <div class="example-card-header">
            <div class="dots"><div class="dot dot-red"></div><div class="dot dot-yellow"></div><div class="dot dot-green"></div></div>
            <span class="example-label">${ex.label}</span>
          </div>
          <div class="example-split">
            <div class="code-panel">${escapeForDisplay(ex.code)}</div>
            <div class="preview-panel">${ex.preview}</div>
          </div>
        </div>
      </div>`;
  });
  html += '</div>';
  return html;
}

function renderQuiz(lesson) {
  let html = '<div class="tab-pane active"><div class="quiz-container">';
  lesson.quiz.forEach((q, qi) => {
    const answered = state.quizAnswers[qi] !== undefined;
    const isCorrect = state.quizAnswers[qi] === q.correct;
    html += `<div class="question-card" id="q-${qi}">
      <div class="question-number">Pregunta ${qi + 1} de ${lesson.quiz.length}</div>
      <div class="question-text">${q.question}</div>
      <div class="options-grid">`;
    q.options.forEach((opt, oi) => {
      let cls = 'option-btn';
      if (answered) {
        if (oi === q.correct) cls += ' correct';
        else if (oi === state.quizAnswers[qi] && !isCorrect) cls += ' wrong';
      }
      html += `<button class="${cls}" ${answered ? 'disabled' : ''} onclick="answerQuiz(${qi}, ${oi})">
        <span class="option-letter">${String.fromCharCode(65 + oi)}</span>
        ${opt}
      </button>`;
    });
    html += `</div>
      <div class="feedback-msg ${answered ? 'show ' + (isCorrect ? 'correct' : 'wrong') : ''}" id="fb-${qi}">
        ${answered ? (isCorrect ? '✅ ' : '❌ ') + q.feedback : ''}
      </div>
    </div>`;
  });
  
  if (Object.keys(state.quizAnswers).length === lesson.quiz.length) {
    const pct = Math.round((state.quizCorrect / lesson.quiz.length) * 100);
    html += `<div class="complete-card">
      <div class="stars-display">${getStarsDisplay(pct)}</div>
      <div class="complete-title">¡Quiz terminado!</div>
      <p style="color:var(--text2);margin:8px 0">${state.quizCorrect} de ${lesson.quiz.length} correctas</p>
      <button class="start-btn" onclick="showTab(3)" style="margin-top:12px">⌨️ Ir a la Práctica →</button>
    </div>`;
  }
  
  html += '</div></div>';
  return html;
}

function answerQuiz(qi, oi) {
  if (state.quizAnswers[qi] !== undefined) return;
  state.quizAnswers[qi] = oi;
  const lesson = state.currentLesson;
  if (oi === lesson.quiz[qi].correct) state.quizCorrect++;
  showTab(2);
}

function renderChallenge(lesson) {
  const ch = lesson.challenge;
  const prog = getLessonProgress(lesson.id);
  let hintsHtml = ch.hints.map(h => `<li>${h}</li>`).join('');
  
  return `<div class="tab-pane active">
    <div class="challenge-card">
      <div class="challenge-instructions">
        <h4>🎯 ${ch.title}</h4>
        <p>${ch.instructions}</p>
        <ul style="margin-top:8px">${hintsHtml}</ul>
      </div>
      <div class="editor-area">
        <div class="editor-toolbar">
          <span class="editor-label">⌨️ Tu código</span>
          <div style="display:flex;gap:8px">
            <button class="run-btn" onclick="runCode()">▶ Ejecutar</button>
            <button class="check-btn" onclick="checkCode()">✅ Verificar</button>
          </div>
        </div>
        <div class="editor-split">
          <textarea class="code-editor" id="code-editor" spellcheck="false" placeholder="Escribe tu código aquí...">${ch.starterCode}</textarea>
          <iframe class="preview-frame" id="preview-frame"></iframe>
        </div>
      </div>
      <div class="challenge-result" id="challenge-result"></div>
    </div>
    ${prog.completed ? `<div class="complete-card" style="margin-top:16px">
      <div class="stars-display">${getStarsDisplay(prog.stars * 20)}</div>
      <div class="complete-title">¡Lección completada!</div>
      <div class="complete-points">${prog.points} <small>puntos ganados</small></div>
    </div>` : ''}
  </div>`;
}

function runCode() {
  const code = document.getElementById('code-editor').value;
  const frame = document.getElementById('preview-frame');
  frame.srcdoc = code;
}

function checkCode() {
  const code = document.getElementById('code-editor').value;
  const lesson = state.currentLesson;
  const result = document.getElementById('challenge-result');
  
  // Run preview first
  runCode();
  
  if (lesson.challenge.checkFn(code)) {
    result.className = 'challenge-result show pass';
    result.innerHTML = '🎉 ¡Excelente trabajo! ¡Tu código es correcto!';
    
    if (!getLessonProgress(lesson.id).completed) {
      completeLesson(lesson);
    }
  } else {
    result.className = 'challenge-result show fail';
    result.innerHTML = '🔧 Revisa tu código. Asegúrate de usar todos los elementos requeridos.';
  }
}

function completeLesson(lesson) {
  // Calculate stars based on quiz performance
  const quizPct = Object.keys(state.quizAnswers).length > 0
    ? state.quizCorrect / lesson.quiz.length
    : 0.5;
  const stars = Math.max(3, Math.round(quizPct * 5));
  const points = lesson.xp + (stars * 10);
  
  state.progress[lesson.id] = { completed: true, stars, points };
  saveProgress();
  updateHome();
  buildSidebar();
  
  launchConfetti();
  
  // Re-render to show completion
  setTimeout(() => showTab(3), 300);
}

function getStarsDisplay(pct) {
  const s = pct >= 90 ? 5 : pct >= 70 ? 4 : pct >= 50 ? 3 : pct >= 30 ? 2 : 1;
  return '⭐'.repeat(s) + '☆'.repeat(5 - s);
}

function launchConfetti() {
  const colors = ['#7c3aed','#06b6d4','#22c55e','#eab308','#ec4899','#f97316'];
  for (let i = 0; i < 40; i++) {
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    piece.style.left = Math.random() * 100 + 'vw';
    piece.style.background = colors[Math.floor(Math.random() * colors.length)];
    piece.style.animationDelay = Math.random() * 1.5 + 's';
    piece.style.animationDuration = (2 + Math.random() * 2) + 's';
    piece.style.borderRadius = Math.random() > 0.5 ? '50%' : '2px';
    document.body.appendChild(piece);
    setTimeout(() => piece.remove(), 4000);
  }
}

function prevLesson() {
  const all = getAllLessons();
  const idx = all.findIndex(l => l.id === state.currentLesson.id);
  if (idx > 0) openLesson(all[idx - 1]);
  else goHome();
}

function nextLesson() {
  const all = getAllLessons();
  const idx = all.findIndex(l => l.id === state.currentLesson.id);
  if (idx < all.length - 1) openLesson(all[idx + 1]);
}

// ==================== NAVIGATION ====================
function goHome() {
  document.getElementById('home-screen').style.display = 'block';
  document.getElementById('lesson-screen').style.display = 'none';
  state.currentLesson = null;
  buildSidebar();
  updateHome();
}

function startFirstLesson() {
  const all = getAllLessons();
  // Find first incomplete
  const next = all.find(l => !getLessonProgress(l.id).completed);
  openLesson(next || all[0]);
}

function goToTrack(track) {
  const lessons = curriculum[track];
  const next = lessons.find(l => !getLessonProgress(l.id).completed);
  openLesson(next || lessons[0]);
}

function toggleSection(id) {
  const el = document.getElementById(id);
  el.style.display = el.style.display === 'none' ? 'block' : el.style.display === '' ? 'none' : 'block';
}

function toggleSidebar() {
  const sb = document.getElementById('sidebar');
  const ov = document.getElementById('sidebar-overlay');
  sb.classList.toggle('open');
  ov.classList.toggle('show');
}

function escapeForDisplay(code) {
  return code.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ==================== INIT ====================
loadProgress();
buildSidebar();
updateHome();
</script>
</body>
</html>
