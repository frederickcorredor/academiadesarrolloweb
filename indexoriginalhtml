<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Desarrollo Web para Niños – Frederick Corredor</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Orbitron:wght@700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a1a;
  --bg2: #0f0f2a;
  --card: #131330;
  --card2: #1a1a3e;
  --purple: #7c3aed;
  --purple-light: #a855f7;
  --blue: #2563eb;
  --cyan: #06b6d4;
  --green: #22c55e;
  --yellow: #eab308;
  --pink: #ec4899;
  --orange: #f97316;
  --red: #ef4444;
  --text: #f0f0ff;
  --text2: #a0a0cc;
  --border: rgba(124,58,237,0.3);
  --glow: 0 0 20px rgba(124,58,237,0.4);
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Nunito', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* BG particles */
body::before {
  content:'';
  position:fixed;
  inset:0;
  background: radial-gradient(ellipse at 20% 20%, rgba(124,58,237,0.15) 0%, transparent 60%),
              radial-gradient(ellipse at 80% 80%, rgba(6,182,212,0.1) 0%, transparent 60%);
  pointer-events:none;
  z-index:0;
}

/* ===== HEADER ===== */
#header {
  background: linear-gradient(135deg, #0d0d2b 0%, #1a0a3e 50%, #0a1a3e 100%);
  border-bottom: 2px solid var(--purple);
  padding: 14px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 4px 30px rgba(124,58,237,0.4);
  gap: 10px;
  flex-wrap: wrap;
}

.header-brand {
  display: flex;
  align-items: center;
  gap: 12px;
}

.header-logo {
  width: 42px; height: 42px;
  background: linear-gradient(135deg, var(--purple), var(--cyan));
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
  box-shadow: var(--glow);
  flex-shrink: 0;
}

.header-title {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(10px, 2vw, 16px);
  line-height: 1.2;
  font-weight: 900;
}
.header-title span { color: var(--cyan); }
.header-title small {
  display: block;
  font-family: 'Nunito', sans-serif;
  font-weight: 600;
  font-size: clamp(9px, 1.5vw, 12px);
  color: var(--purple-light);
  margin-top: 2px;
}

.header-stats {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.stat-badge {
  background: rgba(124,58,237,0.2);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 5px 12px;
  font-size: 13px;
  font-weight: 700;
  display: flex;
  align-items: center;
  gap: 5px;
  white-space: nowrap;
}
.stat-badge.points { border-color: rgba(234,179,8,0.5); background: rgba(234,179,8,0.1); color: var(--yellow); }
.stat-badge.streak { border-color: rgba(249,115,22,0.5); background: rgba(249,115,22,0.1); color: var(--orange); }

/* ===== LAYOUT ===== */
#app {
  display: flex;
  min-height: calc(100vh - 70px);
  position: relative;
  z-index: 1;
}

/* ===== SIDEBAR ===== */
#sidebar {
  width: 270px;
  flex-shrink: 0;
  background: var(--bg2);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  height: calc(100vh - 70px);
  position: sticky;
  top: 70px;
  transition: transform 0.3s;
}

#sidebar::-webkit-scrollbar { width: 4px; }
#sidebar::-webkit-scrollbar-track { background: transparent; }
#sidebar::-webkit-scrollbar-thumb { background: var(--purple); border-radius: 2px; }

.sidebar-section {
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}

.sidebar-section-header {
  padding: 8px 16px;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 2px;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
  user-select: none;
}

.lang-badge {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 1px;
}
.lang-html { background: linear-gradient(135deg, #e34c26, #f16529); color: white; }
.lang-css  { background: linear-gradient(135deg, #264de4, #2965f1); color: white; }
.lang-js   { background: linear-gradient(135deg, #f7df1e, #f0db4f); color: #000; }

.sidebar-progress-bar {
  margin: 4px 16px 8px;
  height: 4px;
  background: rgba(255,255,255,0.1);
  border-radius: 2px;
  overflow: hidden;
}
.sidebar-progress-fill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.5s ease;
}

.lesson-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 16px 9px 24px;
  cursor: pointer;
  transition: all 0.2s;
  font-size: 13px;
  font-weight: 600;
  border-left: 3px solid transparent;
  color: var(--text2);
  position: relative;
}
.lesson-item:hover { background: rgba(124,58,237,0.1); color: var(--text); border-left-color: var(--purple-light); }
.lesson-item.active { background: rgba(124,58,237,0.2); color: var(--text); border-left-color: var(--purple); }
.lesson-item.completed { color: var(--green); }
.lesson-item.completed .lesson-icon { color: var(--green); }
.lesson-item.locked { opacity: 0.4; cursor: not-allowed; }

.lesson-icon { font-size: 14px; flex-shrink: 0; }
.lesson-stars { margin-left: auto; font-size: 10px; letter-spacing: -1px; }

/* ===== MAIN CONTENT ===== */
#main {
  flex: 1;
  overflow-y: auto;
  padding: 24px;
  min-width: 0;
}

/* ===== HOME SCREEN ===== */
#home-screen {
  max-width: 800px;
  margin: 0 auto;
}

.hero-card {
  background: linear-gradient(135deg, #1a0a3e, #0a1a3e);
  border: 2px solid var(--purple);
  border-radius: 20px;
  padding: 32px;
  margin-bottom: 24px;
  text-align: center;
  box-shadow: 0 0 40px rgba(124,58,237,0.3);
  position: relative;
  overflow: hidden;
}
.hero-card::before {
  content:'';
  position:absolute;
  top:-50%; left:-50%;
  width:200%; height:200%;
  background: conic-gradient(transparent 0deg, rgba(124,58,237,0.05) 90deg, transparent 180deg);
  animation: rotate 8s linear infinite;
}
@keyframes rotate { to { transform: rotate(360deg); } }

.hero-title {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(22px, 5vw, 42px);
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: 8px;
  background: linear-gradient(135deg, #fff, var(--cyan));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  position: relative;
}
.hero-subtitle {
  color: var(--purple-light);
  font-size: clamp(14px, 2.5vw, 18px);
  font-weight: 700;
  margin-bottom: 20px;
  position: relative;
}

.progress-overview {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
  margin: 20px 0;
  position: relative;
}

.prog-card {
  background: rgba(0,0,0,0.3);
  border-radius: 14px;
  padding: 16px 12px;
  text-align: center;
  border: 1px solid var(--border);
}
.prog-card .prog-icon { font-size: 28px; margin-bottom: 6px; }
.prog-card .prog-label { font-size: 10px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text2); }
.prog-card .prog-value { font-size: 22px; font-weight: 900; margin: 4px 0; }
.prog-card .prog-bar { height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; margin-top: 8px; overflow:hidden; }
.prog-card .prog-bar-fill { height: 100%; border-radius: 2px; transition: width 0.8s ease; }

.start-btn {
  display: inline-block;
  background: linear-gradient(135deg, var(--purple), var(--blue));
  color: white;
  padding: 14px 36px;
  border-radius: 50px;
  font-size: 16px;
  font-weight: 900;
  cursor: pointer;
  border: none;
  box-shadow: 0 4px 20px rgba(124,58,237,0.5);
  transition: all 0.3s;
  font-family: 'Nunito', sans-serif;
  margin-top: 12px;
  position: relative;
}
.start-btn:hover { transform: translateY(-2px) scale(1.03); box-shadow: 0 8px 30px rgba(124,58,237,0.7); }

.tracks-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 24px;
}

.track-card {
  border-radius: 16px;
  padding: 20px;
  cursor: pointer;
  transition: all 0.3s;
  border: 2px solid transparent;
  text-align: center;
}
.track-card:hover { transform: translateY(-4px); }
.track-html { background: linear-gradient(135deg, rgba(227,76,38,0.15), rgba(241,101,41,0.1)); border-color: rgba(227,76,38,0.4); }
.track-html:hover { border-color: #e34c26; box-shadow: 0 8px 30px rgba(227,76,38,0.3); }
.track-css  { background: linear-gradient(135deg, rgba(38,77,228,0.15), rgba(41,101,241,0.1)); border-color: rgba(38,77,228,0.4); }
.track-css:hover  { border-color: #264de4; box-shadow: 0 8px 30px rgba(38,77,228,0.3); }
.track-js   { background: linear-gradient(135deg, rgba(247,223,30,0.15), rgba(240,219,79,0.1)); border-color: rgba(247,223,30,0.4); }
.track-js:hover   { border-color: #f7df1e; box-shadow: 0 8px 30px rgba(247,223,30,0.3); }

.track-emoji { font-size: 36px; margin-bottom: 10px; }
.track-name { font-family: 'Orbitron', sans-serif; font-size: 13px; font-weight: 900; margin-bottom: 4px; }
.track-desc { font-size: 11px; color: var(--text2); }
.track-progress { margin-top: 10px; height: 5px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow:hidden; }
.track-progress-fill { height: 100%; border-radius: 3px; transition: width 0.8s; }

/* ===== LESSON SCREEN ===== */
#lesson-screen { max-width: 860px; margin: 0 auto; display: none; }

.lesson-header {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 24px;
  padding: 20px;
  background: var(--card);
  border-radius: 16px;
  border: 1px solid var(--border);
}

.lesson-number {
  background: linear-gradient(135deg, var(--purple), var(--blue));
  color: white;
  width: 52px; height: 52px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; font-weight: 900;
  flex-shrink: 0;
  box-shadow: var(--glow);
}

.lesson-meta { flex: 1; }
.lesson-title { font-size: clamp(16px, 3vw, 24px); font-weight: 900; line-height: 1.2; margin-bottom: 4px; }
.lesson-subtitle { font-size: 13px; color: var(--text2); }

.lesson-xp-badge {
  background: rgba(234,179,8,0.15);
  border: 1px solid rgba(234,179,8,0.4);
  color: var(--yellow);
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 800;
  white-space: nowrap;
}

/* TABS */
.lesson-tabs {
  display: flex;
  gap: 4px;
  margin-bottom: 20px;
  background: var(--card);
  padding: 6px;
  border-radius: 14px;
  border: 1px solid var(--border);
  overflow-x: auto;
}

.lesson-tab {
  flex: 1;
  padding: 10px 16px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  border: none;
  background: transparent;
  color: var(--text2);
  transition: all 0.2s;
  white-space: nowrap;
  font-family: 'Nunito', sans-serif;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}
.lesson-tab:hover { background: rgba(124,58,237,0.15); color: var(--text); }
.lesson-tab.active { background: linear-gradient(135deg, var(--purple), var(--blue)); color: white; box-shadow: 0 2px 10px rgba(124,58,237,0.4); }
.lesson-tab.done { color: var(--green); }
.lesson-tab.done.active { background: linear-gradient(135deg, var(--green), #16a34a); }

/* TAB CONTENT */
.tab-pane { display: none; }
.tab-pane.active { display: block; animation: fadeIn 0.3s ease; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

/* INTRO TAB */
.intro-content {
  background: var(--card);
  border-radius: 16px;
  padding: 24px;
  border: 1px solid var(--border);
  line-height: 1.8;
  font-size: 15px;
}

.intro-content h3 {
  font-size: 18px;
  font-weight: 900;
  margin: 20px 0 10px;
  color: var(--cyan);
  display: flex;
  align-items: center;
  gap: 8px;
}
.intro-content h3:first-child { margin-top: 0; }

.intro-content p { margin-bottom: 12px; color: #d0d0f0; }

.tip-box {
  background: linear-gradient(135deg, rgba(6,182,212,0.1), rgba(124,58,237,0.1));
  border-left: 4px solid var(--cyan);
  border-radius: 0 12px 12px 0;
  padding: 14px 18px;
  margin: 16px 0;
  font-weight: 600;
}
.tip-box .tip-label { font-size: 11px; font-weight: 900; letter-spacing: 1.5px; text-transform: uppercase; color: var(--cyan); margin-bottom: 4px; }

.code-highlight {
  background: #0d0d1f;
  border: 1px solid rgba(124,58,237,0.3);
  border-radius: 12px;
  padding: 16px;
  font-family: 'Courier New', monospace;
  font-size: 13px;
  line-height: 1.7;
  overflow-x: auto;
  margin: 12px 0;
  position: relative;
}
.code-highlight .tag { color: #f97316; }
.code-highlight .attr { color: #a78bfa; }
.code-highlight .val { color: #86efac; }
.code-highlight .comment { color: #6b7280; font-style: italic; }
.code-highlight .keyword { color: #f0abfc; }
.code-highlight .string { color: #86efac; }
.code-highlight .number { color: #fbbf24; }
.code-highlight .prop { color: #93c5fd; }
.code-highlight .selector { color: #f97316; }

/* EXAMPLE TAB */
.example-section { margin-bottom: 24px; }
.example-card {
  background: var(--card);
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid var(--border);
}
.example-card-header {
  background: var(--card2);
  padding: 12px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.example-card-header .dot { width: 10px; height: 10px; border-radius: 50%; }
.dots { display: flex; gap: 5px; }
.dot-red { background: var(--red); }
.dot-yellow { background: var(--yellow); }
.dot-green { background: var(--green); }
.example-label { font-size: 12px; font-weight: 800; color: var(--text2); }

.example-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 150px;
}
@media(max-width:600px) { .example-split { grid-template-columns: 1fr; } }

.code-panel {
  padding: 16px;
  font-family: 'Courier New', monospace;
  font-size: 12px;
  line-height: 1.7;
  background: #080818;
  overflow-x: auto;
  border-right: 1px solid var(--border);
  white-space: pre;
}

.preview-panel {
  padding: 16px;
  background: white;
  overflow-y: auto;
}

.preview-panel iframe {
  width: 100%;
  height: 100%;
  min-height: 120px;
  border: none;
}

/* QUIZ TAB */
.quiz-container { display: flex; flex-direction: column; gap: 20px; }

.question-card {
  background: var(--card);
  border-radius: 16px;
  padding: 20px;
  border: 1px solid var(--border);
}

.question-number {
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--purple-light);
  margin-bottom: 8px;
}

.question-text {
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 16px;
  line-height: 1.5;
}

.options-grid { display: flex; flex-direction: column; gap: 8px; }

.option-btn {
  padding: 12px 16px;
  border-radius: 10px;
  border: 2px solid rgba(124,58,237,0.25);
  background: rgba(124,58,237,0.07);
  color: var(--text);
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  text-align: left;
  font-family: 'Nunito', sans-serif;
  display: flex;
  align-items: center;
  gap: 10px;
}
.option-btn:hover:not(:disabled) { border-color: var(--purple-light); background: rgba(124,58,237,0.2); transform: translateX(4px); }
.option-btn.correct { border-color: var(--green); background: rgba(34,197,94,0.15); color: var(--green); }
.option-btn.wrong { border-color: var(--red); background: rgba(239,68,68,0.15); color: var(--red); }
.option-btn:disabled { cursor: default; }

.option-letter {
  width: 26px; height: 26px;
  border-radius: 6px;
  background: rgba(124,58,237,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 900;
  flex-shrink: 0;
}
.option-btn.correct .option-letter { background: rgba(34,197,94,0.3); }
.option-btn.wrong .option-letter { background: rgba(239,68,68,0.3); }

.feedback-msg {
  margin-top: 10px;
  padding: 10px 14px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  display: none;
}
.feedback-msg.show { display: block; }
.feedback-msg.correct { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.4); color: var(--green); }
.feedback-msg.wrong { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.4); color: #fca5a5; }

/* CODE CHALLENGE TAB */
.challenge-card {
  background: var(--card);
  border-radius: 16px;
  border: 1px solid var(--border);
  overflow: hidden;
}

.challenge-instructions {
  padding: 20px;
  border-bottom: 1px solid var(--border);
  background: var(--card2);
}
.challenge-instructions h4 { font-size: 15px; font-weight: 900; margin-bottom: 8px; color: var(--yellow); }
.challenge-instructions p { font-size: 14px; color: var(--text2); line-height: 1.6; }
.challenge-instructions ul { margin: 8px 0 0 16px; }
.challenge-instructions li { font-size: 13px; color: var(--text2); margin-bottom: 4px; }

.editor-area {
  display: grid;
  grid-template-rows: auto 1fr;
}

.editor-toolbar {
  background: #0a0a1a;
  padding: 8px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--border);
  gap: 8px;
}
.editor-label { font-size: 11px; font-weight: 800; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text2); }

.run-btn {
  background: linear-gradient(135deg, var(--green), #16a34a);
  color: white;
  border: none;
  padding: 7px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 800;
  cursor: pointer;
  font-family: 'Nunito', sans-serif;
  transition: all 0.2s;
  display: flex; align-items: center; gap: 6px;
}
.run-btn:hover { transform: scale(1.04); box-shadow: 0 4px 15px rgba(34,197,94,0.4); }

.check-btn {
  background: linear-gradient(135deg, var(--purple), var(--blue));
  color: white;
  border: none;
  padding: 7px 20px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 800;
  cursor: pointer;
  font-family: 'Nunito', sans-serif;
  transition: all 0.2s;
  display: flex; align-items: center; gap: 6px;
}
.check-btn:hover { transform: scale(1.04); box-shadow: 0 4px 15px rgba(124,58,237,0.5); }

.editor-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 200px;
}
@media(max-width:600px) { .editor-split { grid-template-columns: 1fr; } }

.code-editor {
  background: #050510;
  border: none;
  color: #e0e0ff;
  font-family: 'Courier New', monospace;
  font-size: 13px;
  padding: 16px;
  resize: none;
  outline: none;
  line-height: 1.7;
  border-right: 1px solid var(--border);
  min-height: 200px;
  tab-size: 2;
}

.preview-frame {
  background: white;
  border: none;
  min-height: 200px;
  width: 100%;
}

.challenge-result {
  padding: 14px 20px;
  border-top: 1px solid var(--border);
  display: none;
  align-items: center;
  gap: 12px;
  font-size: 14px;
  font-weight: 700;
}
.challenge-result.show { display: flex; }
.challenge-result.pass { background: rgba(34,197,94,0.1); color: var(--green); }
.challenge-result.fail { background: rgba(239,68,68,0.1); color: #fca5a5; }

/* COMPLETE SCREEN */
.complete-card {
  background: linear-gradient(135deg, rgba(124,58,237,0.2), rgba(6,182,212,0.1));
  border: 2px solid var(--purple);
  border-radius: 20px;
  padding: 32px;
  text-align: center;
  margin-top: 20px;
  box-shadow: 0 0 40px rgba(124,58,237,0.3);
}
.stars-display { font-size: 40px; letter-spacing: 4px; margin: 16px 0; }
